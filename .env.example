# ── Supabase ────────────────────────────────────────────────
# 클라이언트에 노출되어도 안전한 값 (anon key는 RLS로 보호됨)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ── 서버 전용 (절대 클라이언트 번들에 포함 금지) ──────────────
# RLS를 우회하므로 시스템 작업에만 제한적으로 사용
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ── Claude API ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY

# 모델은 변동 가능하므로 환경변수로 분리 (docs.claude.com에서 최신 확인)
CLAUDE_MODEL_ROUTER=claude-haiku-4-5-20251001
CLAUDE_MODEL_WRITER=claude-sonnet-4-6
CLAUDE_MODEL_REASONER=claude-opus-4-8

# ── 임베딩 (서드파티: Anthropic은 임베딩 모델 미제공) ─────────
# 예시는 OpenAI text-embedding-3-small (1536차원)
EMBEDDING_API_KEY=YOUR_EMBEDDING_KEY
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ── ERP 연동 (더존 ERP-iU / 옴니이솔) ─────────────────────────
# 설계·협의 사항은 docs/ERP_INTEGRATION.md 참고. 방식 확정 전엔 mock 유지.
ERP_ADAPTER=mock              # mock | staging | rest
ERP_BASE_URL=                 # rest 방식: 옴니이솔 REST 게이트웨이 URL
ERP_API_KEY=                  # rest 인증 토큰
ERP_WEBHOOK_SECRET=           # ERP→PMS 인바운드(/api/erp/webhook) 검증
ERP_SYNC_SECRET=              # /api/erp/sync 호출 보호(Vercel Cron)
